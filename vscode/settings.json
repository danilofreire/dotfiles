{
    "chat.tools.terminal.outputLocation": "chat",
    "workbench.colorTheme": "Monokai Pro (Filter Ristretto)",
    "workbench.iconTheme": "Monokai Pro (Filter Ristretto) Icons",
    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "markdown": true,
        "scminput": false,
        "quarto": true
    },
    "terminal.integrated.profiles.osx": {
        "My Shell (Ghostty Env)": {
            "path": "/bin/zsh",
            "args": ["-l"]
        }
    },
    "terminal.integrated.defaultProfile.osx": "My Shell (Ghostty Env)",
    "terminal.integrated.fontSize": 14,
    "diffEditor.maxComputationTime": 0,
    "chat.experimental.useSkillAdherencePrompt": true,
    "roo-cline.debug": false,
    "roo-cline.allowedCommands": [
        "git log",
        "git diff",
        "git show",
        "quarto render",
        "open",
        "jupyter nbconvert",
        "cd",
        "mv",
        "cp",
        "git commit",
        "git push",
        "git pull",
        "git clone",
        "code",
        "brew",
        "uv",
        "quarto",
        "git checkout",
        "git add",
        "playwright_navigate",
        "playwright_fill",
        "playwright_check",
        "playwright_click",
        "playwright_evaluate",
        "python",
        "conda",
        "mkdir",
        "ollama list",
        "ollama",
        "pip install -r jupyter/requirements.txt",
        "pip",
        "ls",
        "npm test",
        "npm install",
        "git status",
        "git",
        "qwen",
        "which",
        "touch",
        "grep",
        "gh",
        "echo",
        "cat",
        "head",
        "npm",
        "wc",
        "Rscript",
        "find",
        "uv pip install -r requirements.txt",
        "playwright",
        "sed",
        "tail",
        "pwd",
        "sort",
        "QUARTO_JUPYTER_KERNEL=datasci185-py312",
        "du",
        "git remote",
        "git push -u origin main"
    ],
    "roo-cline.deniedCommands": [],
    "vim.smartRelativeLine": true,
    "editor.lineNumbers": "relative",
    "editor.multiCursorModifier": "ctrlCmd",
    "workbench.list.multiSelectModifier": "alt",
    "kilo-code.debug": false,
    "kilo-code.allowedCommands": [
        "git log",
        "git diff",
        "git show",
        "python",
        "brew",
        "cd",
        "ls",
        "cp",
        "mv",
        "quarto",
        "R",
        "pkill",
        "pip",
        "grep",
        "which",
        "jupyter",
        "cat",
        "heretic",
        "git",
        "code",
        "conda",
        "find",
        "head",
        "gh",
        "npm",
        "echo",
        "du",
        "xargs",
        "mkdir",
        "export",
        "calibre"
    ],
    "kilo-code.deniedCommands": [],
    "editor.fontSize": 13,
    "chat.tips.enabled": false,
    "inlineChat.notebookAgent": true,
    "workbench.startupEditor": "none",
    "chat.viewSessions.orientation": "stacked",
    "explorer.confirmDragAndDrop": false,
    "claudeCode.preferredLocation": "panel"
}
